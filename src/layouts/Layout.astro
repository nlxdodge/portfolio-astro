---
export interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

import { SEO } from "astro-seo";

import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import MinimalAnalytics from "../components/MinimalAnalytics.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <SEO
      title={title}
      description={description}
      twitter={{
        creator: "@gerbenveenhof",
      }}
      extend={{
        meta: [
          { name: "description", content: description },
          { name: "twitter:title", content: title },
          { name: "twitter:description", content: description },
        ],
      }}
    />
  </head>
  <body>
    <main>
      <Header />
      <slot />
      <Footer />
    </main>
    <script is:inline>
      function pickRandomFromArray(inputArray) {
        return inputArray[Math.floor(Math.random() * inputArray.length)];
      }

      // list of all supported colors
      function getRandomColor() {
        return pickRandomFromArray([
          "orange",
          "purple",
          "pink",
          "green",
          "blue",
        ]);
      }

      // clear the current color, set the new color and update body class
      function setColor(color) {
        const body = document.querySelector("body");
        body.classList.remove(localStorage.getItem("color"));
        body.classList.add(color);
        localStorage.setItem("color", color);
      }

      // on reload, switch to a different random color
      const pageAccessedByReload = window.performance
        .getEntriesByType("navigation")
        .map((navigation) => navigation.type)
        .includes("reload");
      if (pageAccessedByReload) {
        localStorage.removeItem("color");
      }

      // if no color is set in the storage, select a random one
      setColor(
        localStorage.getItem("color") != undefined
          ? localStorage.getItem("color")
          : getRandomColor(),
      );
    </script>
    <!-- Google Analytics -->
    <MinimalAnalytics id="G-01E73RLVK8" />
    <style is:global lang="scss">
      // this is a hack so that the globals.scss file is getting loaded in all components
      // then the pre-processor applies it to all sub-components that have individual styling
    </style>
  </body>
</html>
